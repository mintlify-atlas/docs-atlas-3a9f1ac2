  "keyFeatures": [
    "Command-line batch processing with multiple profiles",
    "Fast hash deduplication and signature analysis",
    "Data carving engine supporting 40+ file formats",
    "OCR powered by Tesseract 5",
    "Face recognition and similar face search",
    "Audio transcription with local and cloud services",
    "Timeline and graph analysis for communications",
    "Custom parsers for WhatsApp, Telegram, Skype, and P2P apps",
    "Similar document and image search",
    "Named Entity Recognition",
    "Extensible with JavaScript and Python scripts",
    "Web API for remote case access",
    "Support for multicases up to 135 million items",
    "Processing profiles: forensic, CSAM, triage, fastmode, blind"
  ],
